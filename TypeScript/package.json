{
	"name": "@arcweave/arcscript",
	"version": "2.0.0",
	"description": "An interpreter for arcscript using antlr4",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "tsc --build",
		"clean": "rm -rf dist",
		"test": "vitest"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/arcweave/arcscript-interpreters.git"
	},
	"keywords": [
		"arcweave",
		"arcscript",
		"antlr4"
	],
	"bugs": {
		"url": "https://github.com/arcweave/arcscript-interpreters/issues"
	},
	"homepage": "https://github.com/arcweave/arcscript-interpreters#readme",
	"author": "Arcweave",
	"license": "ISC",
	"packageManager": "pnpm@10.12.2",
	"files": [
		"dist"
	],
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/lodash.clonedeep": "^4.5.9",
		"eslint": "^10.0.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.3.0",
		"happy-dom": "^20.6.2",
		"jiti": "^2.6.1",
		"pkg-pr-new": "^0.0.63",
		"prettier": "3.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.0",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"antlr4": "4.13.2",
		"bignumber.js": "^9.3.1",
		"lodash.clonedeep": "^4.5.0"
	}
}
